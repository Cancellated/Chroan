# =============== #
# Unity 生成文件 #
# =============== #
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# ===================================== #
# 自动生成的文件和目录 #
# ===================================== #
# 资源数据库和元文件
/[Aa]ssets/AssetStoreTools*
/[Ll]ibrary/
/[Aa]ssets/Plugins/Editor/JetBrains*

# Unity 缓存文件
/.vs/
/.vscode/
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd

# ================================ #
# 特定平台文件 #
# ================================ #
/[Pp]ackages/
/[Ee]xported[Oo]bj/
/ProjectSettings/ProjectVersion.txt
/[Ss]erverConfig.json

# =============================== #
# 不应忽略的关键文件（白名单） #
# =============================== #
!/[Pp]ackages/repositories.config
!/[Pp]rojectSettings/*.asset
!/[Pp]rojectSettings/InputManager.asset
!/[Pp]rojectSettings/TagManager.asset
!/[Pp]rojectSettings/GraphicsSettings.asset
!/[Pp]rojectSettings/QualitySettings.asset
!/[Pp]rojectSettings/Physics2DSettings.asset

# ============================= #
# 操作系统和编辑器临时文件 #
# ============================= #
.DS_Store*
._*
.Spotlight-V100
.Trashes
[Tt]humbs.db
ehthumbs.db
Desktop.ini

